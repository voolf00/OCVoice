#!/usr/bin/env bash
# OCV — One-command launcher for OpenCode + OCVoice
# Usage: ocv start | stop | status | enroll | autostart install | autostart uninstall
set -euo pipefail

OCVOICE_CMD="${OCVOICE_CMD:-ocvoice}"
OPENCODE_PORT="${OPENCODE_PORT:-4096}"
OPENCODE_HOST="${OPENCODE_HOST:-127.0.0.1}"
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

usage() {
    echo "OCV — OpenCode + Voice Control Launcher"
    echo ""
    echo "Usage: ocv <command>"
    echo ""
    echo "Commands:"
    echo "  start              Start OpenCode server + voice control"
    echo "  tui                Open a new terminal with OpenCode TUI"
    echo "  start-voice        Start voice control only (requires running OpenCode)"
    echo "  stop               Stop both OpenCode server and voice control"
    echo "  status             Show status of both services"
    echo "  enroll             Enroll your voice for speaker verification"
    echo "  select [session|project]  Interactive session/project picker"
    echo "  autostart install  Install macOS LaunchAgent (auto-start on login)"
    echo "  autostart uninstall Remove macOS LaunchAgent"
    echo "  autostart status   Show LaunchAgent status"
    echo "  config             Print current configuration"
    echo ""
    echo "Shortcuts after start:"
    echo '  "окей код, переключи модель на claude opus"'
    echo '  "окей код, plan mode"'
    echo '  "окей код, спроси как работает аутентификация"'
}

is_opencode_running() {
    curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 --max-time 2 "http://${OPENCODE_HOST}:${OPENCODE_PORT}/session" 2>/dev/null | grep -q 200
}

is_ocvoice_running() {
    pgrep -f "ocvoice.*start" > /dev/null 2>&1 || pgrep -f "python.*ocvoice" > /dev/null 2>&1
}

_scan_ide_ports() {
    for port in 59020 59010 59000 59499 4096; do
        code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 1 --max-time 1 \
            -u "opencode:${OPENCODE_SERVER_PASSWORD}" "http://127.0.0.1:${port}/session" 2>/dev/null)
        if [ "$code" = "200" ]; then
            OPENCODE_PORT=$port
            return 0
        fi
    done
    return 1
}

cmd_start() {
    echo -e "${GREEN}=== OCV — Starting Voice Control ===${NC}"

    # Don't start opencode serve — OCVoice discovers IDE automatically
    echo -e "${YELLOW}[*]${NC} Looking for OpenCode IDE/CLI server..."
    if _scan_ide_ports; then
        echo -e "${GREEN}[✓]${NC} OpenCode IDE detected on port ${OPENCODE_PORT}"
    elif is_opencode_running; then
        echo -e "${GREEN}[✓]${NC} OpenCode server found on port ${OPENCODE_PORT}"
    else
        echo -e "${YELLOW}[!]${NC} OpenCode not detected. Starting server..."
        opencode serve --port "${OPENCODE_PORT}" --hostname "${OPENCODE_HOST}" > /dev/null 2>&1 &
        sleep 3
    fi

    # Start OCVoice if not running
    if is_ocvoice_running; then
        echo -e "${GREEN}[✓]${NC} OCVoice daemon already running"
    else
        echo -e "${YELLOW}[*]${NC} Starting voice control daemon..."
        # Find a way to launch ocvoice
        SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
        PROJECT_DIR="$(cd "$SCRIPT_DIR/../.." 2>/dev/null && pwd || echo "")"
        
        if command -v ocvoice &>/dev/null; then
            nohup ocvoice start > /tmp/ocvoice-daemon.log 2>&1 &
        elif [ -n "$PROJECT_DIR" ] && [ -f "$PROJECT_DIR/.venv/bin/python3" ]; then
            nohup "$PROJECT_DIR/.venv/bin/python3" -m ocvoice start > /tmp/ocvoice-daemon.log 2>&1 &
        elif [ -f "/Users/voolf/Documents/opencode/OCVoice/.venv/bin/python3" ]; then
            nohup "/Users/voolf/Documents/opencode/OCVoice/.venv/bin/python3" -m ocvoice start > /tmp/ocvoice-daemon.log 2>&1 &
        elif [ -f ".venv/bin/python3" ]; then
            nohup .venv/bin/python3 -m ocvoice start > /tmp/ocvoice-daemon.log 2>&1 &
        elif [ -f "OCVoice/.venv/bin/python3" ]; then
            nohup OCVoice/.venv/bin/python3 -m ocvoice start > /tmp/ocvoice-daemon.log 2>&1 &
        elif [ -f "$HOME/Documents/opencode/OCVoice/.venv/bin/python3" ]; then
            nohup "$HOME/Documents/opencode/OCVoice/.venv/bin/python3" -m ocvoice start > /tmp/ocvoice-daemon.log 2>&1 &
        else
            echo -e "${RED}[✗]${NC} Cannot find ocvoice. Run: ./start.sh from project directory"
            return 1
        fi
        sleep 2
        if is_ocvoice_running; then
            echo -e "${GREEN}[✓]${NC} Voice control daemon running"
        else
            echo -e "${YELLOW}[!]${NC} Voice daemon may take a moment to initialize..."
        fi
    fi

    echo ""
    echo -e "${GREEN}===========================================${NC}"
    echo -e "${GREEN}   OCVoice готов!                          ${NC}"
    echo -e "${GREEN}===========================================${NC}"
    echo ""
    echo "  OCVoice подключён к твоему OpenCode Desktop"
    echo "  Голосовые сообщения → в активную сессию IDE"
    echo ""
    echo "  ┌───────────────────────────────────────┐"
    echo "  │  Говори: 'дарвин, напиши функцию'    │"
    echo "  │  → Уведомление на рабочем столе      │"
    echo "  │  → Сообщение в IDE-сессии           │"
    echo "  │  → AI ответит прямо в IDE           │"
    echo "  └───────────────────────────────────────┘"
    echo ""
    echo "  Для остановки: Ctrl+C  или  ocv stop"
    echo ""
}

cmd_tui() {
    # Open a new terminal window with OpenCode TUI attached to server
    if is_opencode_running; then
        echo -e "${GREEN}[✓]${NC} Opening OpenCode TUI attached to port ${OPENCODE_PORT}..."
    else
        echo -e "${YELLOW}[!]${NC} Server not running. Start first: ocv start"
        exit 1
    fi

    OS=$(uname -s)
    if [ "$OS" = "Darwin" ]; then
        osascript -e "tell application \"Terminal\"
            do script \"opencode attach http://${OPENCODE_HOST}:${OPENCODE_PORT}\"
            activate
        end tell" 2>/dev/null || \
        osascript -e "tell application \"iTerm\"
            tell current window
                create tab with default profile
                tell current session to write text \"opencode attach http://${OPENCODE_HOST}:${OPENCODE_PORT}\"
            end tell
            activate
        end tell" 2>/dev/null || \
        echo "Run manually: opencode attach http://${OPENCODE_HOST}:${OPENCODE_PORT}"
    elif [ "$OS" = "Linux" ]; then
        if command -v gnome-terminal &> /dev/null; then
            gnome-terminal -- opencode attach "http://${OPENCODE_HOST}:${OPENCODE_PORT}" &
        elif command -v xterm &> /dev/null; then
            xterm -e "opencode attach http://${OPENCODE_HOST}:${OPENCODE_PORT}" &
        else
            echo "Run manually: opencode attach http://${OPENCODE_HOST}:${OPENCODE_PORT}"
        fi
    else
        echo "Run manually: opencode attach http://${OPENCODE_HOST}:${OPENCODE_PORT}"
    fi
}

cmd_start_voice() {
    echo -e "${GREEN}=== OCV — Starting Voice Control ===${NC}"

    if ! is_opencode_running; then
        echo -e "${RED}[✗]${NC} OpenCode server is not running on port ${OPENCODE_PORT}"
        echo "    Start it first: opencode serve --port ${OPENCODE_PORT}"
        echo "    Or use: ocv start"
        exit 1
    fi

    if is_ocvoice_running; then
        echo -e "${GREEN}[✓]${NC} OCVoice daemon already running"
    else
        echo -e "${YELLOW}[*]${NC} Starting voice control daemon..."
        ${OCVOICE_CMD} start &
        sleep 2
        echo -e "${GREEN}[✓]${NC} Voice control daemon running"
    fi
}

cmd_stop() {
    echo -e "${YELLOW}=== OCV — Stopping ===${NC}"

    # Stop OCVoice
    if is_ocvoice_running; then
        echo "Stopping voice control..."
        ${OCVOICE_CMD} stop 2>/dev/null || true
        sleep 1
        # Force kill if still running
        pkill -f "ocvoice.*start" 2>/dev/null || true
        echo -e "${GREEN}[✓]${NC} Voice control stopped"
    else
        echo "Voice control not running"
    fi

    # Stop OpenCode
    if is_opencode_running; then
        echo "Stopping OpenCode server..."
        PID=$(lsof -ti:${OPENCODE_PORT} 2>/dev/null || true)
        if [ -n "$PID" ]; then
            kill "$PID" 2>/dev/null || true
            sleep 1
        fi
        echo -e "${GREEN}[✓]${NC} OpenCode server stopped"
    else
        echo "OpenCode server not running"
    fi

    echo -e "${GREEN}=== All stopped ===${NC}"
}

cmd_status() {
    echo "=== OCV Status ==="
    echo ""

    # OpenCode
    if is_opencode_running; then
        echo -e "OpenCode server:  ${GREEN}running${NC} (http://${OPENCODE_HOST}:${OPENCODE_PORT})"
        SESSIONS=$(curl -s "http://${OPENCODE_HOST}:${OPENCODE_PORT}/session" 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d))" 2>/dev/null || echo "?")
        echo "  Sessions: $SESSIONS"
    else
        echo -e "OpenCode server:  ${RED}stopped${NC}"
    fi

    # OCVoice
    if is_ocvoice_running; then
        echo -e "Voice control:    ${GREEN}running${NC}"
    else
        echo -e "Voice control:    ${RED}stopped${NC}"
    fi

    # Enrollments
    ENROLL_DIR="$HOME/.config/ocvoice/enrollments"
    if [ -d "$ENROLL_DIR" ]; then
        COUNT=$(ls "$ENROLL_DIR"/*.npy 2>/dev/null | wc -l | tr -d ' ')
        echo "Voice enrollments: $COUNT"
        for f in "$ENROLL_DIR"/*.npy; do
            [ -f "$f" ] && echo "  - $(basename "$f" .npy)"
        done
    else
        echo "Voice enrollments: none (run 'ocv enroll' to set up)"
    fi
    echo ""
}

cmd_enroll() {
    echo -e "${GREEN}=== OCV — Voice Enrollment ===${NC}"
    echo ""
    /Users/voolf/Documents/opencode/OCVoice/.venv/bin/python3 -m ocvoice enroll
}

cmd_autostart_install() {
    PLIST="$HOME/Library/LaunchAgents/ai.ocvoice.plist"
    mkdir -p "$(dirname "$PLIST")"

    if [ -f "$PLIST" ]; then
        echo -e "${YELLOW}LaunchAgent already installed at $PLIST${NC}"
        echo "Run 'ocv autostart status' for details"
        return
    fi

    cat > "$PLIST" << PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.ocvoice</string>
    <key>ProgramArguments</key>
    <array>
        <string>$(which bash)</string>
        <string>-c</string>
        <string>$(command -v ocv 2>/dev/null || echo "$HOME/.local/bin/ocv") start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>$HOME/Library/Logs/ocvoice.log</string>
    <key>StandardErrorPath</key>
    <string>$HOME/Library/Logs/ocvoice.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>$HOME/.local/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
        <key>OCVOICE_TRAY_ENABLED</key>
        <string>false</string>
    </dict>
</dict>
</plist>
PLISTEOF

    launchctl load "$PLIST" 2>/dev/null || true
    echo -e "${GREEN}[✓]${NC} LaunchAgent installed and loaded"
    echo "    OCVoice will start automatically when you log in"
    echo "    Logs: ~/Library/Logs/ocvoice.log"
}

cmd_autostart_uninstall() {
    PLIST="$HOME/Library/LaunchAgents/ai.ocvoice.plist"

    if [ ! -f "$PLIST" ]; then
        echo "LaunchAgent not installed"
        return
    fi

    launchctl unload "$PLIST" 2>/dev/null || true
    rm -f "$PLIST"
    echo -e "${GREEN}[✓]${NC} LaunchAgent removed"
}

cmd_autostart_status() {
    PLIST="$HOME/Library/LaunchAgents/ai.ocvoice.plist"

    if [ -f "$PLIST" ]; then
        echo "LaunchAgent: installed at $PLIST"
        if launchctl list ai.ocvoice &>/dev/null; then
            echo -e "Status: ${GREEN}loaded${NC}"
        else
            echo -e "Status: ${YELLOW}installed but not loaded${NC}"
        fi
    else
        echo "LaunchAgent: not installed"
        echo "Run 'ocv autostart install' to install"
    fi
}

# ─── Main ───

COMMAND="${1:-}"
case "${COMMAND}" in
    start)          cmd_start ;;
    tui)            cmd_tui ;;
    start-voice)    cmd_start_voice ;;
    stop)           cmd_stop ;;
    status)         cmd_status ;;
    enroll)         cmd_enroll ;;
    autostart)
        case "${2:-}" in
            install)    cmd_autostart_install ;;
            uninstall)  cmd_autostart_uninstall ;;
            status)     cmd_autostart_status ;;
            *)          echo "Usage: ocv autostart <install|uninstall|status>"; exit 1 ;;
        esac
        ;;
    config)         ${OCVOICE_CMD} config ;;
    select)         shift; ${OCVOICE_CMD} select "$@" ;;
    -h|--help|help) usage ;;
    *)              usage; exit 1 ;;
esac
